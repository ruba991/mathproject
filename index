// ═══ HELPERS ═══
function initDots(){const el=document.getElementById('lpDots');el.innerHTML=[1,2,3,4,5].map((n,i)=>`<div class="lpdot" id="ld${i}">${n}</div>`).join('');}
function updH(){document.getElementById('hPts').textContent=G.pts;document.getElementById('hStr').textContent=G.str;document.getElementById('hCor').textContent=G.cor;document.getElementById('lpFill').style.width=(G.lv/5*100)+'%';for(let i=0;i<5;i++){const d=document.getElementById('ld'+i);d.className='lpdot'+(i<G.lv?' fin':i===G.lv?' act':'');}}
function show(id){document.querySelectorAll('.scr').forEach(s=>s.classList.remove('on'));document.getElementById(id).classList.add('on');}
function goHome(){clrT();show('scrHome');document.getElementById('homeBtn').style.display='none';G={pts:0,cor:0,str:0,lv:0,tmr:null,t:0};updH();}
function addP(p){G.pts+=p;updH();}
function hit(b=100){G.cor++;G.str++;addP(b+(G.str>=3?40:0));}
function miss(){G.str=0;updH();}
function clrT(){if(G.tmr){clearInterval(G.tmr);G.tmr=null;}}
function startT(secs,bi,li,cb){clrT();G.t=secs;const bar=document.getElementById(bi),lbl=document.getElementById(li);if(bar){bar.classList.remove('hot');bar.style.width='100%';}G.tmr=setInterval(()=>{G.t--;if(bar)bar.style.width=(G.t/secs*100)+'%';if(lbl)lbl.textContent='⏱ '+G.t;if(G.t<=5&&bar)bar.classList.add('hot');if(G.t<=0){clrT();cb();}},1000);}
function seqH(arr){let h='<div class="seq-row">';arr.forEach((x,i)=>{h+=x==='?'?'<div class="tile blank">؟</div>':`<div class="tile">${x}</div>`;if(i<arr.length-1)h+='<div class="tsep">،</div>';});return h+'<div class="tdots">...</div></div>';}
function lockO(pfx,cnt,ans,chsn){for(let i=0;i<cnt;i++){const b=document.getElementById(pfx+i);if(!b)continue;b.disabled=true;if(i===ans)b.classList.add('yes');if(i===chsn&&i!==ans)b.classList.add('no');}}
function pips(cid,tot,cur){const el=document.getElementById(cid);if(!el)return;el.innerHTML=Array.from({length:tot},(_,i)=>`<div class="spdot ${i<cur?'fin':i===cur?'act':''}"></div>`).join('');}
function drawG(cvId,terms){const c=document.getElementById(cvId);if(!c)return;const ctx=c.getContext('2d'),W=c.width,H=c.height,p=28;ctx.clearRect(0,0,W,H);const mx=Math.max(...terms)*1.14;const sx=(W-p*2)/terms.length,sy=(H-p*2)/mx;ctx.strokeStyle='rgba(255,255,255,.05)';for(let i=0;i<=4;i++){const y=H-p-i*(H-p*2)/4;ctx.beginPath();ctx.moveTo(p,y);ctx.lineTo(W-p,y);ctx.stroke();}ctx.strokeStyle='rgba(255,255,255,.18)';ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(p,H-p);ctx.lineTo(W-p,H-p);ctx.stroke();ctx.beginPath();ctx.moveTo(p,p);ctx.lineTo(p,H-p);ctx.stroke();const pts=terms.map((v,i)=>({x:p+sx*(i+.5),y:H-p-v*sy}));ctx.strokeStyle='rgba(251,191,36,.18)';ctx.lineWidth=1;ctx.setLineDash([4,4]);ctx.beginPath();pts.forEach((pt,i)=>i?ctx.lineTo(pt.x,pt.y):ctx.moveTo(pt.x,pt.y));ctx.stroke();ctx.setLineDash([]);pts.forEach((pt,i)=>{ctx.beginPath();ctx.arc(pt.x,pt.y,6,0,Math.PI*2);ctx.fillStyle='rgba(56,189,248,.2)';ctx.fill();ctx.strokeStyle='#38bdf8';ctx.lineWidth=2;ctx.stroke();ctx.fillStyle='rgba(255,255,255,.65)';ctx.font='bold 10px Cairo,sans-serif';ctx.textAlign='center';ctx.fillText(terms[i],pt.x,pt.y-12);ctx.fillStyle='rgba(255,255,255,.3)';ctx.fillText(i+1,pt.x,H-p+13);});}

// ═══ GAME ═══
function startGame(){G={pts:0,cor:0,str:0,lv:0,tmr:null,t:0};l1i=0;l2i=0;l2done=false;l3i=0;l3ph=0;l4i=0;l4ph=0;l5i=0;l5mSt=0;l5gVis=false;document.getElementById('homeBtn').style.display='';updH();goLv(1);}
function goLv(n){clrT();G.lv=n-1;updH();if(n===1){show('scrL1');rndrL1();}else if(n===2){show('scrL2');initL2();}else if(n===3){show('scrL3');rndrL3();}else if(n===4){show('scrL4');rndrL4();}else if(n===5){G.lv=4;updH();show('scrL5');rndrL5();}else{G.lv=5;updH();showEnd();}}

// ═══ L1 ═══
function rndrL1(){pips('pL1',5,l1i);document.getElementById('nL1').style.display='none';if(l1i>=D1.length){document.getElementById('bL1').innerHTML='<div style="text-align:center;color:var(--neon);padding:18px">🎉 أنهيت المستوى الأول!</div>';document.getElementById('nL1').style.display='inline-flex';document.getElementById('nL1').onclick=()=>goLv(2);clrT();return;}const d=D1[l1i];const K=['أ','ب','ج','د'];let h=`<div class="qtxt">${d.q}</div><div class="opts">`;d.opts.forEach((o,i)=>h+=`<button class="opt" id="op${i}" onclick="l1P(${i})"><span class="okey">${K[i]}</span>${o}</button>`);h+=`</div><div class="fb" id="fb1"></div>`;document.getElementById('bL1').innerHTML=h;startT(20,'tB1','tL1',()=>{lockO('op',d.opts.length,d.a,-1);const f=document.getElementById('fb1');f.className='fb err on';f.innerHTML='⏰ انتهى الوقت! '+d.no;miss();document.getElementById('nL1').style.display='inline-flex';document.getElementById('nL1').onclick=l1Next;});}
function l1P(idx){clrT();const d=D1[l1i];const ok=idx===d.a;lockO('op',d.opts.length,d.a,idx);const f=document.getElementById('fb1');f.className='fb '+(ok?'ok':'err')+' on';f.innerHTML=ok?d.ok:d.no;ok?hit():miss();document.getElementById('nL1').style.display='inline-flex';document.getElementById('nL1').onclick=l1Next;}
function l1Next(){l1i++;rndrL1();}

// ═══ L2 ═══
function initL2(){l2i=0;l2done=false;rndrL2();}
function rndrL2(){if(l2i>=D2.length){endL2();return;}l2done=false;const d=D2[l2i];document.getElementById('rfSeq').textContent=d.s;document.getElementById('rfCnt').textContent=(l2i+1)+' / 5';document.getElementById('rfSt').textContent=G.str;document.getElementById('rfFb').className='fb';document.getElementById('nL2').style.display='none';document.querySelectorAll('.rfb').forEach(b=>{b.className=b.className.replace(' flash','').replace(' dim','');b.disabled=false;});startT(20,'tB2','tL2',()=>{if(!l2done){l2done=true;miss();const f=document.getElementById('rfFb');f.className='fb err on';const nm={ح:'متتابعة حسابية',ه:'متتابعة هندسية',غ:'غير ذلك'};f.innerHTML='⏰ انتهى الوقت! '+nm[d.t]+(d.inf?' — '+d.inf:'');setTimeout(()=>{l2i++;rndrL2();},1400);}});}
function rfAns(t){if(l2done)return;l2done=true;clrT();const d=D2[l2i];const ok=t===d.t;const bm={ح:'.rfb-c',ه:'.rfb-h',غ:'.rfb-n'};document.querySelector(bm[t]).classList.add(ok?'flash':'dim');if(!ok)document.querySelector(bm[d.t]).classList.add('flash');ok?hit(80):miss();const nm={ح:'متتابعة حسابية',ه:'متتابعة هندسية',غ:'غير ذلك'};const f=document.getElementById('rfFb');f.className='fb '+(ok?'ok':'err')+' on';f.innerHTML=(ok?'✅ ':'❌ ')+nm[d.t]+(d.inf?' — '+d.inf:'');document.getElementById('rfSt').textContent=G.str;setTimeout(()=>{l2i++;rndrL2();},1500);}
function endL2(){clrT();document.getElementById('rfSeq').innerHTML='<span style="color:var(--neon)">🎉 أنهيت المستوى الثاني!</span>';document.querySelectorAll('.rfb').forEach(b=>b.disabled=true);document.getElementById('nL2').style.display='inline-flex';}

// ═══ L3 ═══
function rndrL3(){pips('pL3',5,l3i);document.getElementById('nL3').style.display='none';if(l3i>=D3.length){document.getElementById('bL3').innerHTML='<div style="text-align:center;color:var(--neon);padding:18px">🎉 أنهيت المستوى الثالث!</div>';document.getElementById('nL3').style.display='inline-flex';document.getElementById('nL3').onclick=()=>goLv(4);clrT();return;}const d=D3[l3i];const tm={ح:0,ه:1,غ:2};const tn=['متتابعة حسابية','متتابعة هندسية','غير ذلك'];let h=`<div class="qtxt">صنِّف المتتابعة:</div>${seqH(d.seq)}`;if(l3ph===0){h+=`<div class="qlbl">ما نوع المتتابعة؟</div><div class="opts g3">`;tn.forEach((o,i)=>h+=`<button class="opt" id="t3${i}" onclick="l3T('${['ح','ه','غ'][i]}')">${o}</button>`);h+=`</div>`;}else if(l3ph===1){h+=`<div class="fb ok on" style="margin-bottom:10px">${d.ft}</div>`;h+=`<div class="qlbl">ما السبب في تصنيفها؟</div><div class="opts">`;d.jo.forEach((o,i)=>h+=`<button class="opt" id="j3${i}" onclick="l3J(${i})">${o}</button>`);h+=`</div>`;}else{h+=`<div class="fb ok on">${d.fj}</div>`;if(d.base)h+=`<div style="background:rgba(251,191,36,.07);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:10px 14px;color:var(--spark);font-weight:700;font-size:.84rem;margin-top:9px">📌 ${d.base}</div>`;clrT();document.getElementById('nL3').style.display='inline-flex';document.getElementById('nL3').onclick=l3Next;}document.getElementById('bL3').innerHTML=h;if(l3ph<2){startT(20,'tB3','tL3',()=>{if(l3ph===0){document.querySelectorAll('[id^="t3"]').forEach(b=>b.disabled=true);document.getElementById('t3'+tm[d.t]).classList.add('yes');miss();l3ph=1;setTimeout(rndrL3,800);}else if(l3ph===1){document.querySelectorAll('[id^="j3"]').forEach(b=>b.disabled=true);document.getElementById('j3'+d.ja).classList.add('yes');miss();l3ph=2;setTimeout(rndrL3,800);}});}}
function l3T(t){clrT();const d=D3[l3i];const m={ح:0,ه:1,غ:2};document.querySelectorAll('[id^="t3"]').forEach(b=>b.disabled=true);const ok=t===d.t;document.getElementById('t3'+m[t]).classList.add(ok?'yes':'no');if(!ok)document.getElementById('t3'+m[d.t]).classList.add('yes');ok?hit():miss();l3ph=1;setTimeout(rndrL3,700);}
function l3J(idx){clrT();const d=D3[l3i];const ok=idx===d.ja;document.querySelectorAll('[id^="j3"]').forEach(b=>b.disabled=true);document.getElementById('j3'+idx).classList.add(ok?'yes':'no');if(!ok)document.getElementById('j3'+d.ja).classList.add('yes');ok?hit():miss();l3ph=2;setTimeout(rndrL3,800);}
function l3Next(){l3i++;l3ph=0;rndrL3();}

// ═══ L4 ═══
function rndrL4(){pips('pL4',5,l4i);document.getElementById('nL4').style.display='none';if(l4i>=D4.length){document.getElementById('bL4').innerHTML='<div style="text-align:center;color:var(--neon);padding:18px">🎉 أنهيت المستوى الرابع!</div>';document.getElementById('nL4').style.display='inline-flex';document.getElementById('nL4').onclick=()=>goLv(5);clrT();return;}const d=D4[l4i];const K=['أ','ب','ج','د'];let h='';if(d.kind==='hid'){h+=`<div class="qtxt">أوجد الحد الناقص وصنِّف المتتابعة:</div>${seqH(d.d)}`;if(l4ph===0){h+=`<div class="qlbl">الخطوة 1 — ما نوع المتتابعة؟</div><div class="opts g3">`;d.to.forEach((o,i)=>h+=`<button class="opt" id="ht${i}" onclick="l4HT(${i})">${o}</button>`);h+=`</div>`;}else if(l4ph===1){h+=`<div class="fb ok on" style="margin-bottom:10px">${d.ft}</div>`;h+=`<div class="qlbl">الخطوة 2 — ما الأساس؟</div><div class="opts g2">`;d.ao.forEach((o,i)=>h+=`<button class="opt" id="ha${i}" onclick="l4HA(${i})"><span class="okey">${K[i]}</span>${o}</button>`);h+=`</div>`;}else if(l4ph===2){h+=`<div class="fb ok on" style="margin-bottom:10px">${d.fa}</div>`;h+=`<div class="qlbl">الخطوة 3 — ما قيمة الحد الناقص (؟)؟</div>`;h+=`<div class="inrow"><input type="number" class="ninput" id="hidInp" placeholder="؟" onkeydown="if(event.key==='Enter')l4Sub()"><button class="btn btn-neon btn-sm" onclick="l4Sub()">تحقق ✓</button></div>`;h+=`<div class="fb" id="fbHid"></div>`;}else{h+=`<div class="fb ok on">${d.fn}</div>`;clrT();document.getElementById('nL4').style.display='inline-flex';document.getElementById('nL4').onclick=l4Next;}}else{h+=`<div class="qtxt">${d.q}</div><div class="opts g2">`;d.opts.forEach((o,i)=>h+=`<button class="opt" id="bp${i}" onclick="l4B(${i})"><span class="okey">${K[i]}</span>${o}</button>`);h+=`</div><div class="fb" id="fbBase"></div>`;}document.getElementById('bL4').innerHTML=h;if(d.kind==='hid'&&l4ph<3){startT(20,'tB4','tL4',()=>{if(l4ph===0){document.querySelectorAll('[id^="ht"]').forEach(b=>b.disabled=true);document.getElementById('ht'+d.ta).classList.add('yes');miss();l4ph=1;setTimeout(rndrL4,800);}else if(l4ph===1){document.querySelectorAll('[id^="ha"]').forEach(b=>b.disabled=true);document.getElementById('ha'+d.aa).classList.add('yes');miss();l4ph=2;setTimeout(rndrL4,800);}else if(l4ph===2){const f=document.getElementById('fbHid');if(f){f.className='fb err on';f.innerHTML='⏰ انتهى الوقت! '+d.fn;}miss();l4ph=3;setTimeout(rndrL4,900);}});}else if(d.kind==='base'){startT(20,'tB4','tL4',()=>{document.querySelectorAll('[id^="bp"]').forEach(b=>b.disabled=true);document.getElementById('bp'+d.a).classList.add('yes');const f=document.getElementById('fbBase');if(f){f.className='fb err on';f.innerHTML='⏰ انتهى الوقت! '+d.no;}miss();document.getElementById('nL4').style.display='inline-flex';document.getElementById('nL4').onclick=l4Next;});}}
function l4HT(idx){clrT();const d=D4[l4i];const ok=idx===d.ta;document.querySelectorAll('[id^="ht"]').forEach(b=>b.disabled=true);document.getElementById('ht'+idx).classList.add(ok?'yes':'no');if(!ok)document.getElementById('ht'+d.ta).classList.add('yes');ok?hit():miss();l4ph=1;setTimeout(rndrL4,700);}
function l4HA(idx){clrT();const d=D4[l4i];const ok=idx===d.aa;document.querySelectorAll('[id^="ha"]').forEach(b=>b.disabled=true);document.getElementById('ha'+idx).classList.add(ok?'yes':'no');if(!ok)document.getElementById('ha'+d.aa).classList.add('yes');ok?hit():miss();l4ph=2;setTimeout(rndrL4,700);}
function l4Sub(){clrT();const d=D4[l4i];const v=parseFloat(document.getElementById('hidInp').value);if(isNaN(v))return;const ok=v===d.ans;ok?hit(120):miss();const f=document.getElementById('fbHid');f.className='fb '+(ok?'ok':'err')+' on';f.innerHTML=ok?d.fn:`❌ الإجابة الصحيحة: ${d.ans}<br>${d.fn}`;document.getElementById('hidInp').disabled=true;document.querySelector('[onclick="l4Sub()"]').disabled=true;l4ph=3;setTimeout(rndrL4,900);}
function l4B(idx){
  clrT();
  const d = D4[l4i];
  const ok = idx === d.a;

  document.querySelectorAll('[id^="bp"]').forEach(b => b.disabled = true);

  document.getElementById('bp' + idx).classList.add(ok ? 'yes' : 'no');
  if(!ok) document.getElementById('bp' + d.a).classList.add('yes');

  ok ? hit() : miss();

  const f = document.getElementById('fbBase');
  f.className = 'fb ' + (ok ? 'ok' : 'err') + ' on';
  f.innerHTML = ok ? d.ok : d.no;

  document.getElementById('nL4').style.display = 'inline-flex';
  document.getElementById('nL4').onclick = l4Next;
};
function l4Next(){l4i++;l4ph=0;rndrL4();}

// ═══ L5 ═══
function rndrL5(){pips('pL5',5,l5i);document.getElementById('nL5').style.display='none';if(l5i>=D5.length){document.getElementById('bL5').innerHTML='<div style="text-align:center;color:var(--spark);padding:18px">🎉 أنهيت جميع المستويات! أنت سيد المتتابعات 🏆</div>';document.getElementById('nL5').style.display='inline-flex';document.getElementById('nL5').onclick=()=>goLv(6);clrT();return;}const d=D5[l5i];const K=['أ','ب','ج','د'];let h='';
if(d.kind==='graph'){h+=`<div class="qtxt">${d.q}</div>`;h+=`<button class="peek-btn" id="pkBtn" onclick="tglPk()">${l5gVis?'🙈 إخفاء المتتابعة':'👁 عرض المتتابعة'}</button>`;h+=`<div id="pkBox" style="display:${l5gVis?'block':'none'}"><div style="background:rgba(18,28,62,.9);border-radius:10px;padding:9px 13px;font-family:Tajawal,monospace;font-size:1rem;color:var(--spark);text-align:center;margin-bottom:7px">${d.seqTxt}</div><div class="graphbox"><canvas id="gCvs" width="310" height="165"></canvas></div></div>`;h+=`<div class="opts">`;d.opts.forEach((o,i)=>h+=`<button class="opt" id="g5${i}" onclick="l5G(${i})">${o}</button>`);h+=`</div><div class="fb" id="fbG"></div>`;document.getElementById('bL5').innerHTML=h;if(l5gVis)setTimeout(()=>drawG('gCvs',d.terms),40);startT(20,'tB5','tL5',()=>{document.querySelectorAll('[id^="g5"]').forEach(b=>b.disabled=true);document.getElementById('g5'+d.a).classList.add('yes');const f=document.getElementById('fbG');if(f){f.className='fb err on';f.innerHTML='⏰ '+d.no;}miss();document.getElementById('nL5').style.display='inline-flex';document.getElementById('nL5').onclick=l5Next;});
}else if(d.kind==='term'){h+=seqH(d.seq);h+=`<div class="qtxt">${d.q.replace(/\n/g,'<br>')}</div><div class="opts g2">`;d.opts.forEach((o,i)=>h+=`<button class="opt" id="tm${i}" onclick="l5Tm(${i})"><span class="okey">${K[i]}</span>${o}</button>`);h+=`</div><div class="fb" id="fbTm"></div>`;document.getElementById('bL5').innerHTML=h;startT(20,'tB5','tL5',()=>{document.querySelectorAll('[id^="tm"]').forEach(b=>b.disabled=true);document.getElementById('tm'+d.a).classList.add('yes');const f=document.getElementById('fbTm');if(f){f.className='fb err on';f.innerHTML='⏰ '+d.no;}miss();document.getElementById('nL5').style.display='inline-flex';document.getElementById('nL5').onclick=l5Next;});
}else if(d.kind==='master'){const st=d.steps[l5mSt];h+=seqH(d.seq);h+=`<div class="qtxt">${st.q.replace(/\n/g,'<br>')}</div><div class="opts">`;st.opts.forEach((o,i)=>h+=`<button class="opt" id="ms${i}" onclick="l5Ms(${i})"><span class="okey">${K[i]||i+1}</span>${o}</button>`);h+=`</div><div class="fb" id="fbMs"></div>`;document.getElementById('bL5').innerHTML=h;startT(20,'tB5','tL5',()=>{document.querySelectorAll('[id^="ms"]').forEach(b=>b.disabled=true);document.getElementById('ms'+st.a).classList.add('yes');const f=document.getElementById('fbMs');if(f){f.className='fb err on';f.innerHTML='⏰ '+st.no;}miss();document.getElementById('nL5').style.display='inline-flex';document.getElementById('nL5').onclick=l5MsNx;});}}
function tglPk(){l5gVis=!l5gVis;const d=D5[l5i];const b=document.getElementById('pkBox');const btn=document.getElementById('pkBtn');if(b)b.style.display=l5gVis?'block':'none';if(btn)btn.textContent=l5gVis?'🙈 إخفاء المتتابعة':'👁 عرض المتتابعة';if(l5gVis)setTimeout(()=>drawG('gCvs',d.terms),40);}
function l5G(idx){clrT();const d=D5[l5i];const ok=idx===d.a;document.querySelectorAll('[id^="g5"]').forEach(b=>b.disabled=true);document.getElementById('g5'+idx).classList.add(ok?'yes':'no');if(!ok)document.getElementById('g5'+d.a).classList.add('yes');ok?hit():miss();const f=document.getElementById('fbG');f.className='fb '+(ok?'ok':'err')+' on';f.innerHTML=ok?d.ok:d.no;document.getElementById('nL5').style.display='inline-flex';document.getElementById('nL5').onclick=l5Next;}
function l5Tm(idx){clrT();const d=D5[l5i];const ok=idx===d.a;document.querySelectorAll('[id^="tm"]').forEach(b=>b.disabled=true);document.getElementById('tm'+idx).classList.add(ok?'yes':'no');if(!ok)document.getElementById('tm'+d.a).classList.add('yes');ok?hit(120):miss();const f=document.getElementById('fbTm');f.className='fb '+(ok?'ok':'err')+' on';f.innerHTML=ok?d.ok:d.no;document.getElementById('nL5').style.display='inline-flex';document.getElementById('nL5').onclick=l5Next;}
function l5Ms(idx){clrT();const d=D5[l5i];const st=d.steps[l5mSt];const ok=idx===st.a;document.querySelectorAll('[id^="ms"]').forEach(b=>b.disabled=true);document.getElementById('ms'+idx).classList.add(ok?'yes':'no');if(!ok)document.getElementById('ms'+st.a).classList.add('yes');ok?hit(150):miss();const f=document.getElementById('fbMs');f.className='fb '+(ok?'ok':'err')+' on';f.innerHTML=ok?st.ok:st.no;document.getElementById('nL5').style.display='inline-flex';document.getElementById('nL5').onclick=l5MsNx;}
function l5MsNx(){l5mSt++;if(l5mSt<D5[l5i].steps.length){rndrL5();}else{l5mSt=0;l5Next();}}
function l5Next(){l5i++;l5gVis=false;rndrL5();}

// ═══ END ═══
function showEnd(){show('scrEnd');const pts=G.pts;document.getElementById('eScore').textContent=pts;const pct=pts/2500;let tr='🏆',ti='أنت سيد المتتابعات! 👑';if(pct<.4){tr='🌱';ti='جهد جيد! راجع المادة وحاول مجدداً';}else if(pct<.65){tr='🥈';ti='رائع! تقدم ملحوظ — استمر!';}else if(pct<.85){tr='🥇';ti='ممتاز! أداء متميز جداً!';}document.getElementById('eTrphy').textContent=tr;document.getElementById('eTitle').textContent=ti;
const s=pct>=.85?3:pct>=.6?2:1;document.getElementById('eStars').innerHTML=[1,2,3].map(i=>`<span class="estr${i<=s?' glow':''}" style="animation-delay:${i*.2}s">${i<=s?'⭐':'☆'}</span>`).join('');
}

function startFrom(level){
  G={pts:0,cor:0,str:0,lv:0,tmr:null,t:0};
  updH();
  document.getElementById('homeBtn').style.display='';
  goLv(level);
}

initDots();updH();
</script>
