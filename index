


<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title> مشروع الرياضيات</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
:root{
  --night:#050814;--navy:#080f28;--glass:#0d1535;--glass2:#121c3e;--glass3:#172247;
  --indigo:#818cf8;--spark:#fbbf24;--neon:#34d399;--coral:#f87171;--sky:#38bdf8;
  --text:#e0e7ff;--dim:#475569;--bi:rgba(129,140,248,.15);
}
*{box-sizing:border-box;margin:0;padding:0}html{font-size:16px}
body{font-family:'Cairo','Tajawal',sans-serif;background:var(--night);color:var(--text);min-height:100vh;direction:rtl;overflow-x:hidden;}
#stars{position:fixed;inset:0;z-index:0;pointer-events:none;}
.nebula{position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse 60% 50% at 15% 20%,rgba(99,102,241,.13) 0%,transparent 60%),radial-gradient(ellipse 50% 40% at 85% 75%,rgba(251,191,36,.08) 0%,transparent 60%);}
.wrap{position:relative;z-index:1;max-width:800px;margin:0 auto;padding:14px 14px 52px;}
.hud{display:flex;align-items:center;gap:8px;margin-bottom:12px;flex-wrap:wrap;}
.pill{display:flex;align-items:center;gap:5px;background:rgba(13,21,53,.85);border:1px solid rgba(129,140,248,.2);border-radius:99px;padding:6px 13px;font-size:.77rem;font-weight:700;backdrop-filter:blur(8px);}
.pv{color:var(--spark);font-weight:900;font-size:.88rem;}
.sp1{flex:1}
.lp-wrap{margin-bottom:14px;}
.lp-rail{height:4px;background:rgba(129,140,248,.12);border-radius:99px;overflow:hidden;}
.lp-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--indigo),var(--sky),var(--spark));transition:width .6s cubic-bezier(.4,0,.2,1);box-shadow:0 0 10px var(--indigo);}
.lp-dots{display:flex;justify-content:space-between;margin-top:8px;}
.lpdot{width:28px;height:28px;border-radius:50%;background:var(--glass);border:2px solid rgba(129,140,248,.2);display:flex;align-items:center;justify-content:center;font-size:.62rem;font-weight:900;color:var(--dim);transition:all .35s;}
.lpdot.act{background:var(--indigo);border-color:var(--spark);color:#fff;box-shadow:0 0 12px var(--indigo);}
.lpdot.fin{background:var(--neon);border-color:var(--neon);color:var(--night);}
.scr{display:none;}
.scr.on{display:block;animation:lift .35s ease both;}
@keyframes lift{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
.card{background:rgba(13,21,53,.8);border:1px solid rgba(129,140,248,.18);border-radius:22px;padding:26px 22px 22px;margin-bottom:14px;position:relative;overflow:hidden;backdrop-filter:blur(12px);box-shadow:0 8px 32px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.05);}
.card::before{content:'';position:absolute;top:-100px;left:-100px;width:260px;height:260px;border-radius:50%;background:radial-gradient(circle,rgba(129,140,248,.08),transparent 65%);pointer-events:none;}
.card-spark::before{background:radial-gradient(circle,rgba(251,191,36,.09),transparent 65%);}
.card-neon::before{background:radial-gradient(circle,rgba(52,211,153,.08),transparent 65%);}
.rw-row{display:flex;align-items:flex-start;gap:14px;margin-bottom:20px;}
.rw-face{flex-shrink:0;width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,#6366f1,#fbbf24);display:flex;align-items:center;justify-content:center;font-size:1.9rem;box-shadow:0 0 20px rgba(99,102,241,.5);animation:fg 3s ease-in-out infinite;}
@keyframes fg{0%,100%{box-shadow:0 0 20px rgba(99,102,241,.5)}50%{box-shadow:0 0 30px rgba(99,102,241,.8),0 0 50px rgba(251,191,36,.3)}}
.rw-bubble{background:rgba(18,28,62,.9);border:1px solid rgba(251,191,36,.2);border-radius:0 18px 18px 18px;padding:14px 17px;flex:1;font-size:.95rem;line-height:1.85;}
.rw-name{font-size:.66rem;font-weight:900;color:var(--spark);margin-bottom:3px;text-transform:uppercase;letter-spacing:.6px;}
.lvbdg{display:inline-flex;align-items:center;gap:6px;background:rgba(129,140,248,.1);border:1px solid rgba(129,140,248,.3);border-radius:99px;padding:5px 14px;font-size:.7rem;font-weight:800;color:var(--indigo);margin-bottom:14px;letter-spacing:.3px;}
.spips{display:flex;gap:6px;justify-content:center;margin-bottom:14px;}
.spdot{width:9px;height:9px;border-radius:50%;background:var(--glass2);border:2px solid rgba(129,140,248,.2);transition:all .3s;}
.spdot.fin{background:var(--neon);border-color:var(--neon);}
.spdot.act{background:var(--spark);border-color:var(--spark);box-shadow:0 0 6px var(--spark);}
.timer-w{margin-bottom:14px;}
.timer-rail{height:6px;background:rgba(129,140,248,.1);border-radius:99px;overflow:hidden;}
.timer-bar{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--neon),var(--sky),var(--spark));transition:width 1s linear;box-shadow:0 0 8px var(--neon);}
.timer-bar.hot{background:linear-gradient(90deg,var(--coral),var(--spark));box-shadow:0 0 8px var(--coral);}
.timer-lbl{font-size:.74rem;color:var(--dim);margin-top:3px;text-align:left;}
.seq-row{display:flex;flex-wrap:wrap;gap:8px;align-items:center;justify-content:center;margin:15px 0;}
.tile{width:54px;height:54px;border-radius:12px;background:rgba(23,34,71,.9);border:2px solid rgba(56,189,248,.25);display:flex;align-items:center;justify-content:center;font-family:'Tajawal',monospace;font-size:1.1rem;font-weight:800;color:var(--sky);animation:tIn .3s ease both;box-shadow:0 2px 8px rgba(0,0,0,.3);}
.tile:nth-child(1){animation-delay:.04s}.tile:nth-child(3){animation-delay:.08s}.tile:nth-child(5){animation-delay:.12s}.tile:nth-child(7){animation-delay:.16s}.tile:nth-child(9){animation-delay:.2s}
@keyframes tIn{from{opacity:0;transform:scale(.55)rotate(-10deg)}to{opacity:1;transform:scale(1)rotate(0)}}
.tile.blank{background:rgba(251,191,36,.08);border-color:var(--spark);color:var(--spark);font-size:1.5rem;box-shadow:0 0 12px rgba(251,191,36,.2);}
.tsep{color:var(--dim);font-size:1rem;font-weight:900;align-self:center;}
.tdots{color:var(--dim);font-size:1.2rem;font-weight:900;align-self:center;}
.opts{display:grid;gap:9px;margin-top:13px;}
.opts.g2{grid-template-columns:1fr 1fr;}
.opts.g3{grid-template-columns:1fr 1fr 1fr;}
.opt{background:rgba(18,28,62,.8);border:2px solid rgba(129,140,248,.15);border-radius:13px;padding:13px 15px;font-family:'Cairo',sans-serif;font-size:.87rem;font-weight:700;color:var(--text);cursor:pointer;text-align:right;transition:all .2s;display:flex;align-items:center;gap:9px;backdrop-filter:blur(6px);}
.opt:hover:not(:disabled){border-color:var(--spark);background:rgba(251,191,36,.07);transform:translateX(-3px);}
.opt.yes{border-color:var(--neon)!important;background:rgba(52,211,153,.1)!important;color:var(--neon)!important;box-shadow:0 0 12px rgba(52,211,153,.2)!important;}
.opt.no{border-color:var(--coral)!important;background:rgba(248,113,113,.07)!important;color:#fca5a5!important;}
.opt:disabled{cursor:default;}
.okey{width:27px;height:27px;border-radius:7px;background:rgba(129,140,248,.12);border:1px solid rgba(129,140,248,.25);display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:900;flex-shrink:0;color:var(--indigo);}
.fb{border-radius:13px;padding:13px 16px;margin-top:12px;font-size:.86rem;line-height:1.78;display:none;}
.fb.on{display:block;animation:lift .25s ease;}
.fb.ok{background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.3);color:var(--neon);}
.fb.err{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.25);color:#fca5a5;}
.qtxt{font-size:.97rem;font-weight:700;line-height:1.85;margin-bottom:8px;}
.qlbl{font-size:.7rem;font-weight:900;color:var(--spark);text-transform:uppercase;letter-spacing:.4px;margin:14px 0 7px;}
.rfseq{font-family:'Tajawal',monospace;font-size:1.6rem;font-weight:800;color:var(--sky);text-align:center;padding:22px 14px;background:rgba(18,28,62,.8);border-radius:16px;border:2px solid rgba(56,189,248,.2);min-height:72px;display:flex;align-items:center;justify-content:center;letter-spacing:1px;animation:tIn .28s ease;box-shadow:0 4px 20px rgba(0,0,0,.3);}
.rf-info{display:flex;justify-content:space-between;font-size:.78rem;color:var(--dim);margin-bottom:10px;}
.rf-btns{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:13px;}
.rfb{padding:14px 5px;border-radius:13px;font-family:'Cairo',sans-serif;font-size:.86rem;font-weight:800;cursor:pointer;border:2px solid;text-align:center;transition:all .2s;backdrop-filter:blur(6px);}
.rfb-c{background:rgba(56,189,248,.09);border-color:var(--sky);color:var(--sky);}
.rfb-c:hover{background:rgba(56,189,248,.2);transform:translateY(-3px);}
.rfb-h{background:rgba(251,191,36,.09);border-color:var(--spark);color:var(--spark);}
.rfb-h:hover{background:rgba(251,191,36,.2);transform:translateY(-3px);}
.rfb-n{background:rgba(129,140,248,.09);border-color:var(--indigo);color:var(--indigo);}
.rfb-n:hover{background:rgba(129,140,248,.2);transform:translateY(-3px);}
.rfb.flash{transform:scale(1.08);}
.rfb.dim{opacity:.35;}
.ninput{background:rgba(23,34,71,.9);border:2px solid var(--spark);border-radius:11px;padding:10px 12px;font-family:'Tajawal',monospace;font-size:1.1rem;font-weight:800;color:var(--spark);width:80px;text-align:center;outline:none;transition:border-color .2s;box-shadow:0 0 12px rgba(251,191,36,.15);}
.ninput:focus{border-color:var(--sky);}
.inrow{display:flex;gap:10px;align-items:center;margin-top:12px;flex-wrap:wrap;}
.graphbox{background:rgba(13,21,53,.8);border:1px solid rgba(129,140,248,.2);border-radius:14px;padding:12px;margin:10px 0;backdrop-filter:blur(8px);}
canvas{display:block;margin:0 auto;}
.peek-btn{display:inline-flex;align-items:center;gap:6px;background:rgba(18,28,62,.8);border:1px solid rgba(56,189,248,.25);border-radius:9px;padding:6px 13px;font-size:.74rem;font-weight:800;cursor:pointer;color:var(--sky);transition:all .2s;margin-bottom:9px;font-family:'Cairo',sans-serif;backdrop-filter:blur(6px);}
.peek-btn:hover{border-color:var(--sky);}
.btn{display:inline-flex;align-items:center;gap:7px;padding:11px 22px;border-radius:12px;font-family:'Cairo',sans-serif;font-size:.88rem;font-weight:800;cursor:pointer;border:none;transition:all .22s;}
.btn-main{background:linear-gradient(135deg,#6366f1,#fbbf24);color:#fff;box-shadow:0 4px 16px rgba(99,102,241,.3);}
.btn-main:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(99,102,241,.4);}
.btn-ghost{background:rgba(18,28,62,.8);color:var(--text);border:1px solid rgba(129,140,248,.2);backdrop-filter:blur(6px);}
.btn-ghost:hover{border-color:var(--spark);}
.btn-neon{background:linear-gradient(135deg,#065f46,#34d399);color:var(--night);}
.btn-sm{padding:8px 15px;font-size:.79rem;}
.nav-row{display:flex;gap:9px;justify-content:space-between;margin-top:14px;flex-wrap:wrap;}
.trophy{font-size:5.5rem;text-align:center;animation:trin .9s cubic-bezier(.34,1.56,.64,1);}
@keyframes trin{from{transform:scale(0)rotate(-180deg)}to{transform:scale(1)rotate(0)}}
.escore{font-size:3.2rem;font-weight:900;color:var(--spark);text-align:center;}
.esub{color:var(--dim);text-align:center;margin-bottom:14px;}
.strow{display:flex;justify-content:center;gap:9px;margin:10px 0;}
.estr{font-size:2.2rem;}
.estr.glow{animation:sp .35s ease both;}
@keyframes sp{0%{transform:scale(0)}65%{transform:scale(1.45)}100%{transform:scale(1)}}
.bdgrow{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin:12px 0;}
.bdgcard{background:rgba(18,28,62,.8);border:1px solid rgba(129,140,248,.2);border-radius:11px;padding:10px 12px;text-align:center;min-width:82px;}
.bdgi{font-size:1.5rem;}.bdgl{font-size:.65rem;color:var(--dim);margin-top:2px;font-weight:700;}
.lbrow{display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:9px;margin-bottom:5px;background:rgba(18,28,62,.7);}
.lbrow.me{border:1px solid var(--spark);background:rgba(251,191,36,.05);}
.lbrnk{font-weight:900;width:24px;}.lbnm{flex:1;font-weight:700;}.lbpt{font-weight:900;color:var(--spark);}
@media(max-width:560px){
  .rf-btns,.opts.g3{grid-template-columns:1fr;}
  .opts.g2{grid-template-columns:1fr;}
  .tile{width:46px;height:46px;font-size:.9rem;}
  .card{padding:18px 13px;}
}
</style>
</head>
<body>
<canvas id="stars"></canvas>
<div class="nebula"></div>
<div class="wrap">
  <div class="hud">
    <div class="pill">⭐ <span class="pv" id="hPts">0</span></div>
    <div class="pill">🔥 <span class="pv" id="hStr">0</span></div>
    <div class="pill">✅ <span class="pv" id="hCor">0</span><span style="color:var(--dim)">/25</span></div>
    <div class="sp1"></div>
    <button class="btn btn-ghost btn-sm" id="homeBtn" style="display:none" onclick="goHome()">🏠</button>
  </div>
  <div class="lp-wrap">
    <div class="lp-rail"><div class="lp-fill" id="lpFill" style="width:0%"></div></div>
    <div class="lp-dots" id="lpDots"></div>
  </div>


<div class="scr on" id="scrHome">
  <div class="card" style="text-align:center;padding:34px 22px">
      <div class="rw-row" style="text-align:right;margin-bottom:24px">
        <div class="rw-face">👩‍🏫</div>
        <div class="rw-bubble">
          <!-- <div class="rw-name">روان</div> -->
          ⚡مع روان وميار ووسن..هنا يبدأ التحدي!
        </div>
      </div>
      <div style="font-size:1.55rem;font-weight:900;color:var(--spark);margin-bottom:6px">مشروع الرياضيات</div>
      <div style="color: #d9d7d7;font: size 0.1em;rem;margin-bottom:22px"> أ. تهاني التعزي </div>
      <!-- <button class="btn btn-main" onclick="startGame()" style="font-size:.95rem;padding:13px 30px">🚀 ابدأ اللعبة</button> -->
    
      <div style="font-size:1.55rem;font-weight:900;color:var(--spark);margin-bottom:20px">
      اختر المرحلة
    </div>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:15px">

      <button class="btn btn-main" onclick="startFrom(1)">المستوى 1</button>
      <button class="btn btn-main" onclick="startFrom(2)">المستوى 2</button>
      <button class="btn btn-main" onclick="startFrom(3)">المستوى 3</button>
      <button class="btn btn-main" onclick="startFrom(4)">المستوى 4</button>
      <button class="btn btn-main" onclick="startFrom(5)">المستوى 5</button>

    </div>
    

  </div>
  </div>


    

  <!-- المستوى 1 -->
  <div class="scr" id="scrL1">
    <div class="card card-spark">
      <div class="lvbdg">📖 المستوى الأول · 5 أسئلة</div>
      <div class="spips" id="pL1"></div>
      <div class="timer-w"><div class="timer-rail"><div class="timer-bar" id="tB1" style="width:100%"></div></div><div class="timer-lbl" id="tL1">⏱ 20</div></div>
      <div id="bL1"></div>
    </div>
    <div class="nav-row">
      <button class="btn btn-ghost" onclick="goHome()">🏠</button>
      <button class="btn btn-main" id="nL1" style="display:none" onclick="l1Next()">التالي ←</button>
    </div>
  </div>

  <!-- المستوى 2 -->
  <div class="scr" id="scrL2">
    <div class="card">
      <div class="lvbdg">⚡ المستوى الثاني · 5 تصنيف سريع</div>
      <div class="timer-w"><div class="timer-rail"><div class="timer-bar" id="tB2" style="width:100%"></div></div><div class="timer-lbl" id="tL2">⏱ 20</div></div>
      <div class="rf-info"><span id="rfCnt">1 / 5</span><span>تتالي: <strong style="color:var(--spark)" id="rfSt">0</strong> 🔥</span></div>
      <div class="rfseq" id="rfSeq">...</div>
      <div class="rf-btns">
        <button class="rfb rfb-c" onclick="rfAns('ح')">➕ حسابية</button>
        <button class="rfb rfb-h" onclick="rfAns('ه')">✖️ هندسية</button>
        <button class="rfb rfb-n" onclick="rfAns('غ')">❓ غير ذلك</button>
      </div>
      <div class="fb" id="rfFb"></div>
    </div>
    <div class="nav-row">
      <button class="btn btn-ghost" onclick="goHome()">🏠</button>
      <button class="btn btn-main" id="nL2" style="display:none" onclick="goLv(3)">المستوى التالي ←</button>
    </div>
  </div>

  <!-- المستوى 3 -->
  <div class="scr" id="scrL3">
    <div class="card card-spark">
      <div class="lvbdg">💡 المستوى الثالث · 5 تصنيف وتبرير</div>
      <div class="spips" id="pL3"></div>
      <div class="timer-w"><div class="timer-rail"><div class="timer-bar" id="tB3" style="width:100%"></div></div><div class="timer-lbl" id="tL3">⏱ 20</div></div>
      <div id="bL3"></div>
    </div>
    <div class="nav-row">
      <button class="btn btn-ghost" onclick="goHome()">🏠</button>
      <button class="btn btn-main" id="nL3" style="display:none" onclick="l3Next()">التالي ←</button>
    </div>
  </div>

  <!-- المستوى 4 -->
  <div class="scr" id="scrL4">
    <div class="card card-neon">
      <div class="lvbdg">🕵️ المستوى الرابع · 5 أسئلة</div>
      <div class="spips" id="pL4"></div>
      <div class="timer-w"><div class="timer-rail"><div class="timer-bar" id="tB4" style="width:100%"></div></div><div class="timer-lbl" id="tL4">⏱ 20</div></div>
      <div id="bL4"></div>
    </div>
    <div class="nav-row">
      <button class="btn btn-ghost" onclick="goHome()">🏠</button>
      <button class="btn btn-main" id="nL4" style="display:none" onclick="l4Next()">التالي ←</button>
    </div>
  </div>

  <!-- المستوى 5 -->
  <div class="scr" id="scrL5">
    <div class="card card-spark">
      <div class="lvbdg">🏆 المستوى الخامس · التحدي الأخير</div>
      <div class="spips" id="pL5"></div>
      <div class="timer-w"><div class="timer-rail"><div class="timer-bar" id="tB5" style="width:100%"></div></div><div class="timer-lbl" id="tL5">⏱ 20</div></div>
      <div id="bL5"></div>
    </div>
    <div class="nav-row">
      <button class="btn btn-ghost" onclick="goHome()">🏠</button>
      <button class="btn btn-main" id="nL5" style="display:none" onclick="l5Next()">التالي ←</button>
    </div>
  </div>

  <!-- نهاية اللعبة -->
  <div class="scr" id="scrEnd">
    <div class="card" style="text-align:center">
      <div class="trophy" id="eTrphy">🏆</div>
      <div style="font-size:1.3rem;font-weight:900;color:var(--spark);margin:10px 0" id="eTitle"></div>
      <div class="strow" id="eStars"></div>
      <div class="escore" id="eScore">0</div>
      <div class="esub">نقطة</div>
      <div style="display:flex;gap:9px;justify-content:center;margin-top:20px;flex-wrap:wrap">
        <button class="btn btn-main" onclick="startGame()">🔄 العب مجدداً</button>
      </div>
    </div>
  </div>
</div>

<script>
// ═══ STARFIELD ═══
(function(){
  const c=document.getElementById('stars'),ctx=c.getContext('2d');
  let W,H,st=[];
  function rsz(){W=c.width=innerWidth;H=c.height=innerHeight;st=Array.from({length:120},()=>({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.2+.3,s:Math.random()*.003+.001,t:Math.random()*Math.PI*2}));}
  rsz();addEventListener('resize',rsz);
  function fr(){ctx.clearRect(0,0,W,H);st.forEach(s=>{s.t+=s.s;const a=.3+.5*Math.abs(Math.sin(s.t));ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);ctx.fillStyle=`rgba(200,210,255,${a})`;ctx.fill();});requestAnimationFrame(fr);}
  fr();
})();

// ═══ STATE ═══
let G={pts:0,cor:0,str:0,lv:0,tmr:null,t:0};

// ═══ المستوى 1 — 5 أسئلة ═══
